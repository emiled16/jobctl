# jobctl environment variables
#
# Copy this file to `.env` and fill in the values you need. The repo's
# `.envrc` automatically loads `.env` via `dotenv_if_exists`, so direnv
# picks these up when you `cd` into the project.
#
#   cp .env.example .env
#   direnv allow
#
# Nothing here is committed; `.env` is gitignored.

# ---------------------------------------------------------------------------
# LLM providers
# ---------------------------------------------------------------------------

# OpenAI provider (used when `llm.provider = openai` in .jobctl/config.yaml).
# The variable name is configurable via `llm.openai.api_key_env`; this is the
# default that jobctl reads.
OPENAI_API_KEY=

# Optional: override the OpenAI API base URL (proxies, Azure, etc.).
# OPENAI_BASE_URL=https://api.openai.com/v1

# Ollama provider host. Only needed if you run Ollama somewhere other than
# the default localhost; otherwise leave unset and configure `llm.ollama.host`
# in `.jobctl/config.yaml`.
# OLLAMA_HOST=http://localhost:11434

# ---------------------------------------------------------------------------
# Ingestion
# ---------------------------------------------------------------------------

# Personal access token for higher GitHub API rate limits during repo
# ingestion. A classic token with `public_repo` (or `repo` for private) is
# enough. Leave empty to use unauthenticated requests.
GITHUB_TOKEN=

# ---------------------------------------------------------------------------
# Editor / TUI
# ---------------------------------------------------------------------------

# Used by the YAML review loops in resume/cover-letter generation when the
# user picks the "edit" action. Falls back to `vi` if unset.
# EDITOR=nvim

# ---------------------------------------------------------------------------
# ML caches (optional)
# ---------------------------------------------------------------------------

# Where Hugging Face Transformers stores downloaded embedding models. Setting
# this to a project-local path keeps your global cache clean.
# HF_HOME=.cache/huggingface
# TRANSFORMERS_CACHE=.cache/huggingface

# Silence the noisy "tokenizers parallelism" warning under Textual workers.
# TOKENIZERS_PARALLELISM=false

# Optional when vector_store.mode is remote. Local Qdrant mode under
# .jobctl/qdrant does not need an API key or a separate server process.
# QDRANT_API_KEY=

# ---------------------------------------------------------------------------
# Logging
# ---------------------------------------------------------------------------

# Default Python logging level for ad-hoc scripts. The `jobctl` CLI exposes
# `--verbose` / `--quiet` flags as the preferred way to control verbosity.
# JOBCTL_LOG_LEVEL=INFO
